{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "{{PROJECT_NAME}}",
  "version": "0.0.1",
  "identifier": "com.example.{{PROJECT_NAME}}",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "title": "{{PROJECT_NAME}}",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
