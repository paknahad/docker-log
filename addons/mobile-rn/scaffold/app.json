    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.{{PROJECT_NAME}}"
    },
    "android": {
      "package": "com.example.{{PROJECT_NAME}}",
      "adaptiveIcon": {
